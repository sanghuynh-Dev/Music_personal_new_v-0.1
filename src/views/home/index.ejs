<%- include('../partials/header') %>

<div class="home-container">
    <% if (userID && recentlyPlayed && recentlyPlayed.length > 0) { %>
        <section class="home-section recently-played-section">
            <h2 class="section-title">Recently Played</h2>
            <div class="recently-played-grid">
                <% recentlyPlayed.forEach(function(historyItem) { %>
                    <% const song = historyItem.song; %>
                    <div class="recent-song-card cursor-pointer" onclick="playSong('<%= song._id %>')">
                        <img src="<%= song.imageUrl?.url || 'https://res.cloudinary.com/dqynaodv1/image/upload/v1717904033/resources/images/default-thumbnail.png' %>" alt="<%= song.title %>">
                        <div class="recent-meta">
                            <h4><%= song.title %></h4>
                            <p><%= song.artist %></p>
                        </div>
                        <button class="recent-play-btn" title="Play">
                            <i class="ti-control-play"></i>
                        </button>
                    </div>
                <% }); %>
            </div>
        </section>
    <% } %>

    <div class="home-content-split">
        <section class="home-section main-songs-feed">
            <h2 class="section-title">Explore Music</h2>
            
            <div class="songs-list-container">
                <% if (songs && songs.length > 0) { %>
                    <div class="songs-table">
                        <div class="songs-table-header">
                            <div class="col-index">#</div>
                            <div class="col-title">Title</div>
                            <div class="col-genre">Genre</div>
                            <div class="col-plays"><i class="ti-headphone"></i></div>
                            <div class="col-actions"></div>
                        </div>
                        
                        <% songs.forEach(function(song, index) { %>
                            <div class="song-row" data-id="<%= song._id %>">
                                <div class="col-index">
                                    <span class="row-num"><%= index + 1 %></span>
                                    <button class="row-play-btn" onclick="playSong('<%= song._id %>')" title="Play">
                                        <i class="ti-control-play"></i>
                                    </button>
                                </div>
                                <div class="col-title">
                                    <img src="<%= song.imageUrl?.url || 'https://res.cloudinary.com/dqynaodv1/image/upload/v1717904033/resources/images/default-thumbnail.png' %>" alt="<%= song.title %>" class="song-row-img">
                                    <div class="song-row-info">
                                        <div class="song-row-title"><%= song.title %></div>
                                        <a href="/profile/<%= song.uploadedBy._id %>" class="song-row-artist"><%= song.artist %></a>
                                    </div>
                                </div>
                                <div class="col-genre"><%= song.genre || 'Unknown' %></div>
                                <div class="col-plays"><%= song.playCount || 0 %></div>
                                <div class="col-actions">
                                    <% if (userID) { %>
                                        <button class="action-icon-btn like-btn <%= song.liked ? 'liked' : '' %>" onclick="toggleLike('<%= song._id %>', this)" title="Like">
                                            <i class="<%= song.liked ? 'ti-heart' : 'ti-heart' %>"></i>
                                        </button>
                                        <button class="action-icon-btn opt-btn" onclick="showAddToPlaylistMenu(event, '<%= song._id %>')" title="Add to Playlist">
                                            <i class="ti-more-alt"></i>
                                        </button>
                                    <% } %>
                                </div>
                            </div>
                        <% }); %>
                    </div>
                <% } else { %>
                    <div class="empty-feed">
                        <i class="ti-music-alt"></i>
                        <p>No songs found. Start by uploading some music!</p>
                    </div>
                <% } %>
            </div>
        </section>

        <!-- Sidebar recommendations -->
        <aside class="home-suggestions">
            <h2 class="section-title">Who to follow</h2>
            <div class="suggestions-list">
                <% if (suggestedArtists && suggestedArtists.length > 0) { %>
                    <% suggestedArtists.forEach(function(artist) { %>
                        <div class="suggestion-card">
                            <a href="/profile/<%= artist._id %>" class="suggestion-info">
                                <img src="<%= artist.avatar?.url || 'https://res.cloudinary.com/dqynaodv1/image/upload/v1717904033/resources/images/default-avatar.png' %>" alt="<%= artist.username %>" class="suggestion-img">
                                <div class="suggestion-meta">
                                    <span class="suggestion-name"><%= artist.username %></span>
                                    <span class="suggestion-role"><%= artist.role %></span>
                                </div>
                            </a>
                            <% if (userID) { %>
                                <button class="btn-follow-action follow" onclick="toggleFollow('<%= artist._id %>', this)">Follow</button>
                            <% } else { %>
                                <a href="/login" class="btn-follow-action">Follow</a>
                            <% } %>
                        </div>
                    <% }); %>
                <% } else { %>
                    <p class="empty-suggestions">No new artists to suggest.</p>
                <% } %>
            </div>
        </aside>
    </div>
</div>

<%- include('../partials/footer') %>
