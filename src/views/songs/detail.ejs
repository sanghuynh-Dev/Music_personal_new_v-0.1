<%- include('../partials/header') %>

<div class="song-detail-container event-chang-icon-js">
    <!-- Song Header Banner -->
    <div class="song-detail-header">
        <div class="song-detail-thumbnail-wrapper">
            <img src="<%= song.imageUrl?.url || 'https://res.cloudinary.com/dqynaodv1/image/upload/v1717904033/resources/images/default-thumbnail.png' %>" alt="<%= song.title %>" class="song-detail-thumbnail">
        </div>
        
        <div class="song-detail-meta">
            <span class="detail-label">SONG</span>
            <h1 class="detail-title"><%= song.title %></h1>
            
            <div class="detail-subtext">
                <span class="detail-artist-link">
                    By <a href="/profile/<%= song.uploadedBy._id || song.uploadedBy %>"><%= song.artist %></a>
                </span>
                &bull;
                <span class="detail-genre"><%= song.genre || 'Pop' %></span>
                &bull;
                <span class="detail-plays">
                    <i class="ti-headphone"></i> <strong><%= song.playCount || 0 %></strong> Plays
                </span>
            </div>
            
            <div class="detail-actions">
                <button class="btn-play-song-large play-btn-js" data-id="<%= song._id %>" onclick="playSong('<%= song._id %>')">
                    <svg class="icon-play" id="play-icon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M8 5v14l11-7z"></path>
                    </svg>
                    <svg class="icon-pause" id="pause-icon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" style="display:none;">
                        <path d="M6 5h4v14H6zm8 0h4v14h-4z"></path>
                    </svg> Play
                </button>
                
                <% if (userID) { %>
                    <button class="detail-action-btn like-btn <%= song.liked ? 'liked' : '' %>" data-id="<%= song._id %>" onclick="toggleLike('<%= song._id %>', this)" title="Like">
                        <i class="ti-heart"></i>
                    </button>
                    <button class="detail-action-btn opt-btn" onclick="showAddToPlaylistMenu(event, '<%= song._id %>')" title="Add to Playlist">
                        <i class="ti-more-alt"></i>
                    </button>
                    <% if (song.uploadedBy._id.toString() === userID.toString() || (user && user.role === 'admin')) { %>
                        <a href="/songs/edit/<%= song._id %>" class="detail-action-btn" title="Edit Song Details">
                            <i class="ti-pencil"></i>
                        </a>
                    <% } %>
                <% } else { %>
                    <a href="/login" class="detail-action-btn" title="Log in to Like"><i class="ti-heart"></i></a>
                <% } %>
            </div>
        </div>
    </div>

    <!-- Song Content Area -->
    <div class="song-detail-body">
        <div class="song-info-panel">
            <h3 class="panel-title">About this song</h3>
            <p class="song-description">
                <%= song.description || 'No description provided for this song.' %>
            </p>
        </div>
        
        <!-- Comments Section -->
        <div class="song-comments-panel">
            <h3 class="panel-title">Comments (<span id="comment-count-label">0</span>)</h3>
            
            <% if (userID) { %>
                <form id="comment-form" class="comment-input-form">
                    <div class="comment-input-wrapper">
                        <img src="<%= user?.avatar?.url || 'https://res.cloudinary.com/dqynaodv1/image/upload/v1717904033/resources/images/default-avatar.png' %>" alt="My avatar" class="comment-user-avatar">
                        <textarea id="comment-textarea" placeholder="Add a comment..." required></textarea>
                    </div>
                    <div class="comment-form-actions">
                        <button type="submit" class="btn-submit-comment">Comment</button>
                    </div>
                </form>
            <% } else { %>
                <div class="login-to-comment-msg">
                    <p><a href="/login">Log in</a> to join the conversation.</p>
                </div>
            <% } %>
            
            <ul class="comments-list" id="comments-list-items">
                <!-- Dynamically populated via AJAX -->
                <li class="comments-loading">Loading comments...</li>
            </ul>
        </div>
    </div>
</div>

<script>
    const songId = '<%= song._id %>';
    const commentsList = document.getElementById('comments-list-items');
    const commentCountLabel = document.getElementById('comment-count-label');
    const commentForm = document.getElementById('comment-form');

    // Fetch and render comments
    async function loadComments() {
        try {
            const res = await fetch(`/songs/${songId}/comments`);
            const comments = await res.json();
            
            if (comments.error) {
                commentsList.innerHTML = `<li class="comment-error">Failed to load comments: ${comments.error}</li>`;
                return;
            }
            
            commentCountLabel.innerText = comments.length;
            commentsList.innerHTML = '';
            
            if (comments.length === 0) {
                commentsList.innerHTML = '<li class="no-comments-msg">No comments yet. Be the first to share your thoughts!</li>';
                return;
            }
            
            comments.forEach(comment => {
                const li = document.createElement('li');
                li.className = 'comment-item';
                
                const timeString = new Date(comment.createdAt).toLocaleDateString(undefined, {
                    year: 'numeric',
                    month: 'short',
                    day: 'numeric',
                    hour: '2-digit',
                    minute: '2-digit'
                });
                
                li.innerHTML = `
                    <img src="${comment.user?.avatar?.url || 'https://res.cloudinary.com/dqynaodv1/image/upload/v1717904033/resources/images/default-avatar.png'}" alt="${comment.user?.username}" class="comment-item-avatar">
                    <div class="comment-item-content">
                        <div class="comment-item-header">
                            <a href="/profile/${comment.user?._id}" class="comment-username">${comment.user?.username || 'Deleted User'}</a>
                            <span class="comment-time">${timeString}</span>
                        </div>
                        <p class="comment-text">${escapeHtml(comment.content)}</p>
                    </div>
                `;
                commentsList.appendChild(li);
            });
        } catch (err) {
            console.error('Error loading comments:', err);
            commentsList.innerHTML = '<li class="comment-error">Error loading comments. Please refresh.</li>';
        }
    }

    // Helper to escape HTML characters
    function escapeHtml(text) {
        return text
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/"/g, "&quot;")
            .replace(/'/g, "&#039;");
    }

    // Handle Comment Submission
    if (commentForm) {
        commentForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const textarea = document.getElementById('comment-textarea');
            const content = textarea.value.trim();
            
            if (!content) return;
            
            try {
                const response = await fetch(`/songs/${songId}/comment`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ content })
                });
                const data = await response.json();
                
                if (data.success) {
                    textarea.value = '';
                    loadComments(); // Refresh comment list
                } else {
                    alert(data.error || 'Failed to submit comment');
                }
            } catch (err) {
                console.error('Submit comment error:', err);
                alert('An error occurred. Please try again.');
            }
        });
    }

    // Load comments on mount
    document.addEventListener('DOMContentLoaded', loadComments);
</script>

<%- include('../partials/footer') %>
