<%- include('../partials/header') %>

<div class="upload-container">
    <div class="form-wrapper">
        <h2 class="form-title">Edit Song Details</h2>
        <p class="form-subtitle">Update information for your track.</p>
        
        <form action="/songs/edit/<%= song._id %>" method="POST">
            <div class="form-grid">
                <div class="form-left-col">
                    <div class="form-field-group">
                        <label for="song-title">Song Title</label>
                        <input type="text" id="song-title" name="title" value="<%= song.title %>" required placeholder="Enter track title">
                    </div>
                    
                    <div class="form-field-group">
                        <label for="song-artist">Artist Name</label>
                        <input type="text" id="song-artist" name="artist" value="<%= song.artist %>" placeholder="Enter artist name" style="opacity: 0.7;" readonly>
                    </div>
                    
                    <div class="form-field-group">
                        <label for="song-genre">Genre</label>
                        <input type="text" id="song-genre" name="genre" value="<%= song.genre %>" placeholder="e.g. Pop, Rock, Electronic">
                    </div>
                </div>
                
                <div class="form-right-col">
                    <div class="form-field-group">
                        <label for="song-desc">Description</label>
                        <textarea id="song-desc" name="description" rows="8" placeholder="Tell us about your track..."><%= song.description %></textarea>
                    </div>
                </div>
            </div>
            
            <div class="form-submit-wrapper">
                <a href="/songs/<%= song._id %>" class="btn-cancel" style="display: inline-block; padding: 12px 24px; text-align: center; border-radius: 4px; margin-right: 16px;">Cancel</a>
                <button type="submit" class="btn-submit-track">Save Changes</button>
            </div>
        </form>
    </div>
</div>

<%- include('../partials/footer') %>
