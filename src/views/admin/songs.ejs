<%- include('../partials/header') %>

<div class="admin-dashboard-container event-chang-icon-js">
    <!-- Admin Header -->
    <div class="dashboard-header-simple" style="margin-bottom: 32px;">
        <span class="detail-label">ADMIN PANEL</span>
        <h1 style="font-size: 36px; font-weight: 800;">Song Management</h1>
        
        <!-- Admin Sub-navigation Tab Links -->
        <div class="admin-tabs" style="display: flex; gap: 16px; margin-top: 20px; border-bottom: 1px solid var(--border-color); padding-bottom: 12px;">
            <a href="/admin/dashboard" class="btn-follow-action" style="text-decoration: none;">Dashboard</a>
            <a href="/admin/users" class="btn-follow-action" style="text-decoration: none;">Users</a>
            <a href="/admin/artists" class="btn-follow-action" style="text-decoration: none;">Artists</a>
            <a href="/admin/songs" class="btn-follow-action following" style="text-decoration: none;">Songs</a>
        </div>
    </div>

    <!-- Songs Table -->
    <div class="profile-content">
        <div class="songs-list-container">
            <% if (songs && songs.length > 0) { %>
                <div class="songs-table">
                    <!-- Column Headers -->
                    <div class="songs-table-header" style="grid-template-columns: 50px 3fr 2fr 1.5fr 1fr 1fr; display: grid; align-items: center;">
                        <div class="col-index">#</div>
                        <div>Track Title</div>
                        <div>Uploader</div>
                        <div>Genre</div>
                        <div>Plays</div>
                        <div style="text-align: right; padding-right: 16px;">Action</div>
                    </div>
                    
                    <% songs.forEach(function(s, index) { %>
                        <div class="song-row" id="song-row-<%= s._id %>" style="grid-template-columns: 50px 3fr 2fr 1.5fr 1fr 1fr; display: grid; align-items: center; padding: 12px 16px; border-bottom: 1px solid var(--border-color);">
                            <div class="col-index">
                                <span class="row-num"><%= index + 1 %></span>
                                <button class="row-play-btn play-btn-js" data-id="<%= s._id %>" onclick="playSong('<%= s._id %>')" title="Play">
                                    <svg class="icon-play" id="play-icon" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                                        <path d="M0 5v14l11-7z"></path>
                                    </svg>
                                    <svg class="icon-pause" id="pause-icon" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" style="display:none;">
                                        <path d="M0 5h4v14H0zm8 0h4v14H8z"></path>
                                    </svg>
                                </button>
                            </div>
                            
                            <!-- Track Title / Album art click details link -->
                            <div style="display: flex; align-items: center; gap: 12px; overflow: hidden;">
                                <img src="<%= s.imageUrl?.url || 'https://res.cloudinary.com/dqynaodv1/image/upload/v1717904033/resources/images/default-thumbnail.png' %>" alt="<%= s.title %>" class="song-row-img" style="border-radius: 4px; width: 36px; height: 36px; object-fit: cover;">
                                <a href="/songs/<%= s._id %>" style="font-weight: 700; color: var(--text-color); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"><%= s.title %></a>
                            </div>
                            
                            <!-- Uploader profile link -->
                            <div style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                <a href="/profile/<%= s.uploadedBy?._id || s.uploadedBy %>" style="font-size: 13px; color: var(--secondary-text); font-weight: 600;"><%= s.uploadedBy?.username || 'System Seeded' %></a>
                            </div>
                            
                            <!-- Genre -->
                            <div style="font-size: 13px; color: var(--secondary-text);"><%= s.genre || 'Unknown' %></div>
                            
                            <!-- Plays -->
                            <div style="font-size: 13px; color: var(--secondary-text);"><%= s.playCount || 0 %></div>
                            
                            <!-- Delete action -->
                            <div style="display: flex; justify-content: flex-end; align-items: center;">
                                <button class="action-icon-btn delete-btn" onclick="deleteSongAdmin('<%= s._id %>')" title="Delete track" style="background: none; border: none; color: var(--secondary-text); cursor: pointer;">
                                    <i class="ti-trash"></i>
                                </button>
                            </div>
                        </div>
                    <% }); %>
                </div>
            <% } else { %>
                <div class="empty-feed">
                    <i class="ti-music-alt"></i>
                    <p>No songs found in the system database.</p>
                </div>
            <% } %>
        </div>
    </div>
</div>

<script>
    async function deleteSongAdmin(songId) {
        if (!confirm('Are you sure you want to delete this track? This action cannot be undone.')) {
            return;
        }

        try {
            const response = await fetch(`/admin/song/${songId}/delete`, {
                method: 'POST',
                headers: {
                    'Accept': 'application/json'
                }
            });
            const data = await response.json();

            if (data.success) {
                // Remove row from UI
                const row = document.getElementById(`song-row-${songId}`);
                if (row) {
                    row.remove();
                }
                alert('Song deleted successfully!');
            } else {
                alert(data.error || 'Failed to delete song');
            }
        } catch (err) {
            console.error('Error deleting song:', err);
            alert('An error occurred.');
        }
    }
</script>

<%- include('../partials/footer') %>
