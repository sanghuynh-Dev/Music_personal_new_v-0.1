<%- include('../partials/header') %>

<div class="admin-dashboard-container">
    <!-- Admin Header -->
    <div class="dashboard-header-simple" style="margin-bottom: 32px;">
        <span class="detail-label">ADMIN PANEL</span>
        <h1 style="font-size: 36px; font-weight: 800;">Artist Management</h1>
        
        <!-- Admin Sub-navigation Tab Links -->
        <div class="admin-tabs" style="display: flex; gap: 16px; margin-top: 20px; border-bottom: 1px solid var(--border-color); padding-bottom: 12px;">
            <a href="/admin/dashboard" class="btn-follow-action" style="text-decoration: none;">Dashboard</a>
            <a href="/admin/users" class="btn-follow-action" style="text-decoration: none;">Users</a>
            <a href="/admin/artists" class="btn-follow-action following" style="text-decoration: none;">Artists</a>
            <a href="/admin/songs" class="btn-follow-action" style="text-decoration: none;">Songs</a>
        </div>
    </div>

    <!-- Artists Table -->
    <div class="profile-content">
        <div class="songs-list-container">
            <% if (artists && artists.length > 0) { %>
                <div class="songs-table">
                    <!-- Column Headers -->
                    <div class="songs-table-header" style="grid-template-columns: 50px 2.5fr 2fr 1.2fr 1.2fr 1.2fr; display: grid; align-items: center;">
                        <div class="col-index">#</div>
                        <div>Artist Info</div>
                        <div>Email</div>
                        <div>Tracks</div>
                        <div>Total Plays</div>
                        <div>Followers</div>
                    </div>
                    
                    <% artists.forEach(function(a, index) { %>
                        <div class="song-row" style="grid-template-columns: 50px 2.5fr 2fr 1.2fr 1.2fr 1.2fr; display: grid; align-items: center; padding: 12px 16px; border-bottom: 1px solid var(--border-color);">
                            <div class="col-index">
                                <span class="row-num"><%= index + 1 %></span>
                            </div>
                            
                            <!-- Artist info (links to profile) -->
                            <div style="display: flex; align-items: center; gap: 12px; overflow: hidden;">
                                <img src="<%= a.avatar?.url || 'https://res.cloudinary.com/dqynaodv1/image/upload/v1717904033/resources/images/default-avatar.png' %>" alt="<%= a.username %>" class="song-row-img" style="border-radius: 50%; width: 36px; height: 36px; object-fit: cover;">
                                <a href="/profile/<%= a._id %>" style="font-weight: 700; color: var(--text-color); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"><%= a.username %></a>
                            </div>
                            
                            <!-- Email -->
                            <div style="font-size: 13px; color: var(--secondary-text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"><%= a.email %></div>
                            
                            <!-- Track count -->
                            <div style="font-size: 14px; font-weight: 600; color: var(--text-color);"><%= a.songCount %></div>
                            
                            <!-- Total play counts -->
                            <div style="font-size: 14px; font-weight: 600; color: var(--text-color);"><%= a.totalPlays %></div>
                            
                            <!-- Followers count -->
                            <div style="font-size: 14px; font-weight: 600; color: var(--text-color);"><%= a.followerCount %></div>
                        </div>
                    <% }); %>
                </div>
            <% } else { %>
                <div class="empty-feed">
                    <i class="ti-microphone"></i>
                    <p>No artists found in the system database.</p>
                </div>
            <% } %>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
