<%- include('../partials/header') %>

<div class="admin-dashboard-container">
    <!-- Admin Header -->
    <div class="dashboard-header-simple" style="margin-bottom: 32px;">
        <span class="detail-label">ADMIN PANEL</span>
        <h1 style="font-size: 36px; font-weight: 800;">User Management</h1>
        
        <!-- Admin Sub-navigation Tab Links -->
        <div class="admin-tabs" style="display: flex; gap: 16px; margin-top: 20px; border-bottom: 1px solid var(--border-color); padding-bottom: 12px;">
            <a href="/admin/dashboard" class="btn-follow-action" style="text-decoration: none;">Dashboard</a>
            <a href="/admin/users" class="btn-follow-action following" style="text-decoration: none;">Users</a>
            <a href="/admin/artists" class="btn-follow-action" style="text-decoration: none;">Artists</a>
            <a href="/admin/songs" class="btn-follow-action" style="text-decoration: none;">Songs</a>
        </div>
    </div>

    <!-- Users Table -->
    <div class="profile-content">
        <div class="songs-list-container">
            <% if (users && users.length > 0) { %>
                <div class="songs-table">
                    <!-- Custom Column Headers -->
                    <div class="songs-table-header" style="grid-template-columns: 50px 2.5fr 2fr 1fr 1fr 2fr; display: grid; align-items: center;">
                        <div class="col-index">#</div>
                        <div>User Info</div>
                        <div>Email</div>
                        <div>Role</div>
                        <div>Status</div>
                        <div style="text-align: right; padding-right: 16px;">Actions</div>
                    </div>
                    
                    <% users.forEach(function(u, index) { %>
                        <div class="song-row" id="user-row-<%= u._id %>" style="grid-template-columns: 50px 2.5fr 2fr 1fr 1fr 2fr; display: grid; align-items: center; padding: 12px 16px; border-bottom: 1px solid var(--border-color);">
                            <div class="col-index">
                                <span class="row-num"><%= index + 1 %></span>
                            </div>
                            
                            <!-- User Name/Avatar click link -->
                            <div style="display: flex; align-items: center; gap: 12px; overflow: hidden;">
                                <img src="<%= u.avatar?.url || 'https://res.cloudinary.com/dqynaodv1/image/upload/v1717904033/resources/images/default-avatar.png' %>" alt="<%= u.username %>" class="song-row-img" style="border-radius: 50%; width: 36px; height: 36px; object-fit: cover;">
                                <a href="/profile/<%= u._id %>" style="font-weight: 700; color: var(--text-color); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"><%= u.username %></a>
                            </div>
                            
                            <!-- Email -->
                            <div style="font-size: 13px; color: var(--secondary-text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"><%= u.email %></div>
                            
                            <!-- Role Badge -->
                            <div>
                                <span class="detail-label role-label" id="role-badge-<%= u._id %>" style="font-size: 10px; padding: 2px 8px; border: 1px solid var(--border-color); border-radius: 4px; display: inline-block;"><%= u.role.toUpperCase() %></span>
                            </div>
                            
                            <!-- Ban Status -->
                            <div>
                                <span class="detail-label status-label" id="status-badge-<%= u._id %>" style="font-size: 10px; padding: 2px 8px; border: 1px solid <%= u.status === 'banned' ? '#e74c3c' : 'var(--primary-color)' %>; color: <%= u.status === 'banned' ? '#e74c3c' : 'var(--primary-color)' %>; border-radius: 4px; display: inline-block;"><%= u.status.toUpperCase() %></span>
                            </div>
                            
                            <!-- Action Buttons -->
                            <div style="display: flex; justify-content: flex-end; gap: 12px; align-items: center;">
                                <!-- Promote to Artist button -->
                                <button class="btn-follow-action promote-btn" id="promote-btn-<%= u._id %>" onclick="promoteToArtist('<%= u._id %>')" style="font-size: 11px; padding: 4px 12px; margin: 0; display: <%= u.role === 'user' ? 'inline-block' : 'none' %>">Promote</button>
                                
                                <!-- Ban/Unban toggle button -->
                                <button class="btn-delete-playlist ban-btn" id="ban-btn-<%= u._id %>" onclick="toggleBan('<%= u._id %>')" style="font-size: 11px; padding: 4px 12px; border-color: <%= u.status === 'banned' ? 'var(--primary-color)' : '#e74c3c' %>; color: <%= u.status === 'banned' ? 'var(--primary-color)' : '#e74c3c' %>;"><%= u.status === 'banned' ? 'Unban' : 'Ban' %></button>
                            </div>
                        </div>
                    <% }); %>
                </div>
            <% } else { %>
                <div class="empty-feed">
                    <i class="ti-user"></i>
                    <p>No registered users found in the system database.</p>
                </div>
            <% } %>
        </div>
    </div>
</div>

<script>
    async function promoteToArtist(userId) {
        if (!confirm('Are you sure you want to promote this user to an Artist?')) {
            return;
        }

        try {
            const response = await fetch(`/admin/user/${userId}/promote`, {
                method: 'POST',
                headers: {
                    'Accept': 'application/json'
                }
            });
            const data = await response.json();

            if (data.success) {
                // Update role badge in UI
                const badge = document.getElementById(`role-badge-${userId}`);
                if (badge) {
                    badge.innerText = 'ARTIST';
                }
                
                // Hide promote button
                const btn = document.getElementById(`promote-btn-${userId}`);
                if (btn) {
                    btn.style.display = 'none';
                }
                
                alert('User promoted to Artist successfully!');
            } else {
                alert(data.error || 'Failed to promote user');
            }
        } catch (err) {
            console.error('Error promoting user:', err);
            alert('An error occurred.');
        }
    }

    async function toggleBan(userId) {
        const btn = document.getElementById(`ban-btn-${userId}`);
        const actionText = btn.innerText.toLowerCase();
        
        if (!confirm(`Are you sure you want to ${actionText} this user?`)) {
            return;
        }

        try {
            const response = await fetch(`/admin/user/${userId}/ban`, {
                method: 'POST',
                headers: {
                    'Accept': 'application/json'
                }
            });
            const data = await response.json();

            if (data.success) {
                const newStatus = data.user.status;
                
                // Update status badge
                const statusBadge = document.getElementById(`status-badge-${userId}`);
                if (statusBadge) {
                    statusBadge.innerText = newStatus.toUpperCase();
                    if (newStatus === 'banned') {
                        statusBadge.style.borderColor = '#e74c3c';
                        statusBadge.style.color = '#e74c3c';
                    } else {
                        statusBadge.style.borderColor = 'var(--primary-color)';
                        statusBadge.style.color = 'var(--primary-color)';
                    }
                }

                // Update ban button state
                if (newStatus === 'banned') {
                    btn.innerText = 'Unban';
                    btn.style.borderColor = 'var(--primary-color)';
                    btn.style.color = 'var(--primary-color)';
                } else {
                    btn.innerText = 'Ban';
                    btn.style.borderColor = '#e74c3c';
                    btn.style.color = '#e74c3c';
                }
                
                alert(`User ${newStatus === 'banned' ? 'banned' : 'unbanned'} successfully!`);
            } else {
                alert(data.error || 'Operation failed');
            }
        } catch (err) {
            console.error('Error toggling ban:', err);
            alert('An error occurred.');
        }
    }
</script>

<%- include('../partials/footer') %>
