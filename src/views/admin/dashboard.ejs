<%- include('../partials/header') %>

<div class="admin-dashboard-container">
    <!-- Admin Header -->
    <div class="dashboard-header-simple" style="margin-bottom: 32px;">
        <span class="detail-label">ADMIN PANEL</span>
        <h1 style="font-size: 36px; font-weight: 800;">System Overview</h1>
        
        <!-- Admin Sub-navigation Tab Links -->
        <div class="admin-tabs" style="display: flex; gap: 16px; margin-top: 20px; border-bottom: 1px solid var(--border-color); padding-bottom: 12px;">
            <a href="/admin/dashboard" class="btn-follow-action following" style="text-decoration: none;">Dashboard</a>
            <a href="/admin/users" class="btn-follow-action" style="text-decoration: none;">Users</a>
            <a href="/admin/artists" class="btn-follow-action" style="text-decoration: none;">Artists</a>
            <a href="/admin/songs" class="btn-follow-action" style="text-decoration: none;">Songs</a>
        </div>
    </div>

    <!-- Stats Cards Row -->
    <div class="stats-cards-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 24px; margin-bottom: 40px;">
        <div class="stat-card" style="background-color: var(--secondary-bg); padding: 24px; border-radius: 8px; border: 1px solid var(--border-color); display: flex; align-items: center; gap: 20px;">
            <div class="stat-icon-circle" style="width: 56px; height: 56px; border-radius: 50%; background-color: rgba(52, 152, 219, 0.1); color: #3498db; display: flex; align-items: center; justify-content: center; font-size: 24px;">
                <i class="ti-user"></i>
            </div>
            <div>
                <span style="font-size: 11px; font-weight: 700; color: var(--secondary-text); letter-spacing: 1px; display: block; margin-bottom: 4px;">TOTAL USERS</span>
                <strong style="font-size: 28px; font-weight: 800; color: var(--text-color);"><%= stats.totalUsers %></strong>
            </div>
        </div>

        <div class="stat-card" style="background-color: var(--secondary-bg); padding: 24px; border-radius: 8px; border: 1px solid var(--border-color); display: flex; align-items: center; gap: 20px;">
            <div class="stat-icon-circle" style="width: 56px; height: 56px; border-radius: 50%; background-color: rgba(29, 185, 84, 0.1); color: var(--primary-color); display: flex; align-items: center; justify-content: center; font-size: 24px;">
                <i class="ti-microphone"></i>
            </div>
            <div>
                <span style="font-size: 11px; font-weight: 700; color: var(--secondary-text); letter-spacing: 1px; display: block; margin-bottom: 4px;">ARTISTS</span>
                <strong style="font-size: 28px; font-weight: 800; color: var(--text-color);"><%= stats.totalArtists %></strong>
            </div>
        </div>

        <div class="stat-card" style="background-color: var(--secondary-bg); padding: 24px; border-radius: 8px; border: 1px solid var(--border-color); display: flex; align-items: center; gap: 20px;">
            <div class="stat-icon-circle" style="width: 56px; height: 56px; border-radius: 50%; background-color: rgba(155, 89, 182, 0.1); color: #9b59b6; display: flex; align-items: center; justify-content: center; font-size: 24px;">
                <i class="ti-music-alt"></i>
            </div>
            <div>
                <span style="font-size: 11px; font-weight: 700; color: var(--secondary-text); letter-spacing: 1px; display: block; margin-bottom: 4px;">TRACKS</span>
                <strong style="font-size: 28px; font-weight: 800; color: var(--text-color);"><%= stats.totalSongs %></strong>
            </div>
        </div>

        <div class="stat-card" style="background-color: var(--secondary-bg); padding: 24px; border-radius: 8px; border: 1px solid var(--border-color); display: flex; align-items: center; gap: 20px;">
            <div class="stat-icon-circle" style="width: 56px; height: 56px; border-radius: 50%; background-color: rgba(241, 196, 15, 0.1); color: #f1c40f; display: flex; align-items: center; justify-content: center; font-size: 24px;">
                <i class="ti-headphone"></i>
            </div>
            <div>
                <span style="font-size: 11px; font-weight: 700; color: var(--secondary-text); letter-spacing: 1px; display: block; margin-bottom: 4px;">TOTAL PLAYS</span>
                <strong style="font-size: 28px; font-weight: 800; color: var(--text-color);"><%= stats.totalPlays %></strong>
            </div>
        </div>
    </div>

    <!-- Listings Split Grid -->
    <div class="dashboard-split" style="display: flex; gap: 32px;">
        <!-- Left: Recent Signups -->
        <div style="flex: 1; background-color: var(--secondary-bg); border-radius: 8px; padding: 24px; border: 1px solid var(--border-color);">
            <h3 class="panel-title" style="margin-bottom: 20px; font-size: 18px;">Recent User Registrations</h3>
            <ul style="list-style: none; display: flex; flex-direction: column; gap: 16px;">
                <% if (recentUsers && recentUsers.length > 0) { %>
                    <% recentUsers.forEach(function(u) { %>
                        <li style="display: flex; align-items: center; gap: 12px; justify-content: space-between;">
                            <a href="/profile/<%= u._id %>" style="display: flex; align-items: center; gap: 12px; text-decoration: none; overflow: hidden; flex-grow: 1;">
                                <img src="<%= u.avatar?.url || 'https://res.cloudinary.com/dqynaodv1/image/upload/v1717904033/resources/images/default-avatar.png' %>" alt="<%= u.username %>" style="width: 36px; height: 36px; border-radius: 50%; object-fit: cover;">
                                <div>
                                    <strong style="font-size: 14px; color: var(--text-color);"><%= u.username %></strong>
                                    <span style="font-size: 11px; color: var(--secondary-text); display: block;"><%= u.email %></span>
                                </div>
                            </a>
                            <span class="detail-label" style="font-size: 9px; padding: 2px 6px; border: 1px solid var(--border-color); border-radius: 4px;"><%= u.role.toUpperCase() %></span>
                        </li>
                    <% }); %>
                <% } else { %>
                    <p style="color: var(--secondary-text); font-size: 14px; text-align: center;">No new users registered.</p>
                <% } %>
            </ul>
        </div>

        <!-- Right: Recent Uploads -->
        <div style="flex: 1; background-color: var(--secondary-bg); border-radius: 8px; padding: 24px; border: 1px solid var(--border-color);">
            <h3 class="panel-title" style="margin-bottom: 20px; font-size: 18px;">Recently Uploaded Tracks</h3>
            <ul style="list-style: none; display: flex; flex-direction: column; gap: 16px;">
                <% if (recentSongs && recentSongs.length > 0) { %>
                    <% recentSongs.forEach(function(s) { %>
                        <li style="display: flex; align-items: center; gap: 12px; justify-content: space-between;">
                            <a href="/songs/<%= s._id %>" style="display: flex; align-items: center; gap: 12px; text-decoration: none; overflow: hidden; flex-grow: 1;">
                                <img src="<%= s.imageUrl?.url || 'https://res.cloudinary.com/dqynaodv1/image/upload/v1717904033/resources/images/default-thumbnail.png' %>" alt="<%= s.title %>" style="width: 36px; height: 36px; border-radius: 4px; object-fit: cover;">
                                <div>
                                    <strong style="font-size: 14px; color: var(--text-color); display: block; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"><%= s.title %></strong>
                                    <span style="font-size: 11px; color: var(--secondary-text); display: block;">by <%= s.artist %></span>
                                </div>
                            </a>
                            <span class="detail-label" style="font-size: 9px; padding: 2px 6px; border: 1px solid var(--border-color); border-radius: 4px;"><%= s.genre || 'POP' %></span>
                        </li>
                    <% }); %>
                <% } else { %>
                    <p style="color: var(--secondary-text); font-size: 14px; text-align: center;">No songs uploaded.</p>
                <% } %>
            </ul>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
